# Кузовок - маршрутизация для shared-хостинга
DirectoryIndex index.php

# Все запросы, кроме существующих файлов, направляем на index.php
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /~s409784/kuzovok/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Fallback если mod_rewrite не работает
<IfModule !mod_rewrite.c>
    FallbackResource /~s409784/kuzovok/index.php
</IfModule>

# Защита скрытых файлов
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

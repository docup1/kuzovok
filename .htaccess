# Кузовок - маршрутизация для shared-хостинга
# Без mod_rewrite

DirectoryIndex index.php

# Защита скрытых файлов
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Кэширование статики
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Обработка ошибок
ErrorDocument 404 /~s409784/kuzovok/index.php
